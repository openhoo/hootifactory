# ───────────────────────── Hootifactory environment ─────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# OpenTelemetry (logs, traces, metrics)
# Leave endpoints blank for local JSON logs only. Set OTEL_EXPORTER_OTLP_ENDPOINT
# to an OTLP/HTTP collector base URL (for example http://localhost:4318) to
# export all three signals. Signal-specific endpoints override the base URL.
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=
OTEL_SERVICE_VERSION=0.0.0
OTEL_RESOURCE_ATTRIBUTES=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL_MS=60000

# API server
API_PORT=3000
API_HOST=0.0.0.0
# Public base URL browser users reach the web app at (used in email links)
APP_PUBLIC_URL=http://localhost:5173
# Public base URL clients reach the registry at (used for OCI token realm, Link headers, install snippets)
REGISTRY_PUBLIC_URL=http://localhost:3000

# Local docker-compose demo stack. Published compose ports bind to loopback by
# default; use 0.0.0.0 only on an isolated development network.
# If changing these credentials, update DATABASE_URL and S3_* below to match.
COMPOSE_BIND_ADDRESS=127.0.0.1
COMPOSE_POSTGRES_USER=hootifactory
COMPOSE_POSTGRES_PASSWORD=hootifactory
COMPOSE_POSTGRES_DB=hootifactory
COMPOSE_MINIO_ROOT_USER=hootifactory
COMPOSE_MINIO_ROOT_PASSWORD=hootifactory
COMPOSE_S3_BUCKET=hootifactory

# Postgres
DATABASE_URL=postgres://hootifactory:hootifactory@localhost:5432/hootifactory
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_SECONDS=30
DATABASE_POOL_MAX_LIFETIME_SECONDS=1800
DATABASE_POOL_CONNECTION_TIMEOUT_SECONDS=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=30000
PG_BOSS_POOL_MAX=5

# Object storage (S3-compatible). For MinIO keep FORCE_PATH_STYLE=true.
S3_ENDPOINT=http://localhost:9000
# Optional client-reachable S3/CDN endpoint for presigned artifact download redirects.
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=hootifactory
S3_ACCESS_KEY_ID=hootifactory
S3_SECRET_ACCESS_KEY=hootifactory
S3_FORCE_PATH_STYLE=true

# Auth
# Secret used to sign OIDC state and link-confirmation CSRF cookies.
SESSION_SECRET=dev-session-secret-change-me-please-32chars
# Self-service account and org creation. Leave unset to use environment-aware
# defaults: true in development/test and false in production. Do not set these
# to true in production unless public signup and tenant creation are intentional.
# AUTH_ALLOW_REGISTRATION=true
# AUTH_ALLOW_ORG_CREATION=true
# For production db:seed bootstrap, set SEED_USER and SEED_PASS explicitly.
# Production seed output never prints passwords or owner token secrets.
# In development/test, db:seed defaults to the owner "admin" / "admin" when
# SEED_USER / SEED_PASS are unset, and resets the owner password on every run.
# SEED_ORG=acme
# SEED_USER=
# SEED_PASS=
# Optional source-managed global admins by immutable user id. Removing an id
# revokes only the bootstrap-managed system.admin grant for that user.
# AUTH_SYSTEM_ADMIN_USER_IDS=
AUTH_THROTTLE_MAX_BUCKETS=10000
AUTH_THROTTLE_SWEEP_INTERVAL_SECONDS=300
AUTH_REGISTRATION_MAX_ATTEMPTS=3
AUTH_REGISTRATION_WINDOW_SECONDS=300
# RS256 keypair (PEM) for OCI registry Bearer tokens. Leave blank in dev to auto-generate an ephemeral key.
REGISTRY_JWT_PRIVATE_KEY=
REGISTRY_JWT_PUBLIC_KEY=
# OCI token lifetime (seconds)
REGISTRY_JWT_TTL=300
# Process-wide budget for concurrently admitted whole-body registry writes.
REGISTRY_MAX_INFLIGHT_UPLOAD_BYTES=268435456
# Maximum uncommitted OCI resumable-upload staging bytes per org.
REGISTRY_MAX_STAGED_UPLOAD_BYTES=104857600
# Keep SSRF protection enabled for proxy upstreams. Set true only for isolated
# development tests that intentionally fetch private hosts; refused in production.
REGISTRY_ALLOW_PRIVATE_UPSTREAMS=false

# Email
EMAIL_ENABLED=true
EMAIL_FROM="Hootifactory <noreply@localhost>"
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_SECURE=false
# When SMTP credentials are configured without EMAIL_SMTP_SECURE=true, require STARTTLS before AUTH.
EMAIL_SMTP_REQUIRE_TLS=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
AUTH_PASSWORD_RESET_TTL_SECONDS=1800
AUTH_PASSWORD_RESET_MAX_ATTEMPTS=3
AUTH_PASSWORD_RESET_WINDOW_SECONDS=300
AUTH_OIDC_LINK_TTL_SECONDS=900

# Plugin selection — optional operator allowlists. Unset = register every built-in
# registry/scanner plugin. The app core never names a registry or scanner; these
# only narrow the built-in set without a code change. The offline heuristic
# baseline scanners always run regardless of SCANNERS.
# REGISTRY_PLUGINS=npm,oci,pypi,go,cargo,nuget,pub,swift,chocolatey,winget,homebrew,scoop,rpm,yum,dnf
# SCANNERS=grype,trivy,clamav,osv

# Scanning — generic, cross-scanner runtime knobs (the worker is scanner-agnostic).
SCANNER_ENABLED=false
# External scanner CLIs run through Docker images by default, so the host only
# needs Docker rather than grype/trivy/clamscan installed directly.
SCANNER_CLI_RUNTIME=docker
SCANNER_DOCKER_COMMAND=docker
SCANNER_DOCKER_MEMORY=1g
SCANNER_DOCKER_CPUS=2
SCANNER_DOCKER_PIDS_LIMIT=512
SCANNER_DOCKER_STORAGE_SIZE=
SCANNER_MAX_OUTPUT_BYTES=33554432
# Worker tuning (validated via EnvSchema; a typo or out-of-range value fails boot).
#WORKER_PORT=
SCAN_WORKER_BATCH_SIZE=16
SCAN_WORKER_CONCURRENCY=4
SCAN_WORKER_POLL_INTERVAL_SECONDS=0.5
SCAN_WORKER_MAX_ATTEMPTS=5
UPLOAD_REAPER_INTERVAL_SECONDS=300
UPLOAD_REAPER_BATCH_SIZE=100
BLOB_GC_INTERVAL_SECONDS=300
BLOB_GC_BATCH_SIZE=100
BLOB_GC_GRACE_SECONDS=60
SCAN_RECLAIM_INTERVAL_SECONDS=300
SCAN_RECLAIM_TIMEOUT_SECONDS=900
MAIL_WORKER_BATCH_SIZE=8
MAIL_WORKER_POLL_INTERVAL_SECONDS=0.5
# Per-scanner plugin config — read by each scanner plugin, not the app core.
# Adding a scanner is a new package that owns its own env here, never a core change.
GRYPE_IMAGE=anchore/grype:latest@sha256:e5b03c0ec0bc20a9eaaf84c2dcc97d9890f4dfb4381fce26bffc7dd8527c3d9d
TRIVY_IMAGE=aquasec/trivy:latest@sha256:016eae51fdcf989332a5404af7e8f625cd5d95d7c0907a221d080a996f556500
CLAMAV_IMAGE=clamav/clamav:latest@sha256:d4000290254603e7ee45d4904425c7d98c015af727f402756198fe41a31e7777
CLAMAV_REST_URL=http://localhost:8080
TRIVY_SERVER_URL=
# OSV reaches osv.dev over the network, so it is opt-in.
SCANNER_OSV=false
OSV_API_URL=https://api.osv.dev
SCAN_SCRATCH_DIR=./scratch
# Maximum blob size the scan worker will buffer for heuristic/external scanning.
SCAN_MAX_BYTES=104857600

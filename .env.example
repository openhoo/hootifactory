# ───────────────────────── Hootifactory environment ─────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# API server
API_PORT=3000
API_HOST=0.0.0.0
# Public base URL clients reach the registry at (used for OCI token realm, Link headers, install snippets)
REGISTRY_PUBLIC_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgres://hootifactory:hootifactory@localhost:5432/hootifactory

# Object storage (S3-compatible). For MinIO keep FORCE_PATH_STYLE=true.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hootifactory
S3_ACCESS_KEY_ID=hootifactory
S3_SECRET_ACCESS_KEY=hootifactory
S3_FORCE_PATH_STYLE=true

# Auth
# Secret used to sign/verify UI session cookies (any long random string).
SESSION_SECRET=dev-session-secret-change-me-please-32+chars
# Self-service account and org creation. Defaults to true in development/test
# and false in production; use db:seed or explicit true for production bootstrap.
AUTH_ALLOW_REGISTRATION=true
AUTH_ALLOW_ORG_CREATION=true
# RS256 keypair (PEM) for OCI registry Bearer tokens. Leave blank in dev to auto-generate an ephemeral key.
REGISTRY_JWT_PRIVATE_KEY=
REGISTRY_JWT_PUBLIC_KEY=
# OCI token lifetime (seconds)
REGISTRY_JWT_TTL=300

# Scanning (Phase 3) — external scanner endpoints / binaries
SCANNER_ENABLED=false
CLAMAV_REST_URL=http://localhost:8080
TRIVY_SERVER_URL=
OSV_API_URL=https://api.osv.dev
SCAN_SCRATCH_DIR=./scratch

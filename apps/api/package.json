    "@hootifactory/db": "workspace:*",
    "@hootifactory/email": "workspace:*",
    "@hootifactory/format-cargo": "workspace:*",
    "@hootifactory/format-docker": "workspace:*",
    "@hootifactory/format-go": "workspace:*",
    "@hootifactory/format-npm": "workspace:*",
    "@hootifactory/format-nuget": "workspace:*",
    "@hootifactory/format-pypi": "workspace:*",
    "@hootifactory/observability": "workspace:*",
    "@hootifactory/queue": "workspace:*",
    "@hootifactory/scan-core": "workspace:*",
    "@hootifactory/storage": "workspace:*",
    "@hootifactory/types": "workspace:*",
    "hono": "^4.12.23",
    "hono-openapi": "^1.3.0"
  }

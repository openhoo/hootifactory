{
  "name": "@hootifactory/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "test": "bun run test:unit",
    "test:unit": "bun run ../../scripts/package-tests.ts unit",
    "test:integration": "bun run ../../scripts/package-tests.ts integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hootifactory/auth": "workspace:*",
    "@hootifactory/config": "workspace:*",

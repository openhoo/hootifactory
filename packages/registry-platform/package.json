{
  "name": "@hootifactory/registry-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./assets": "./src/assets/index.ts",
    "./content": "./src/content/index.ts",
    "./governance": "./src/governance/index.ts",
    "./inventory": "./src/inventory/index.ts",
    "./packages": "./src/packages/index.ts",
    "./repositories": "./src/repositories/index.ts",
    "./routing": "./src/routing/index.ts",
    "./runtime": "./src/runtime/index.ts"
  },
  "scripts": {
    "test": "bun run ../../scripts/package-tests.ts unit",
    "test:unit": "bun run ../../scripts/package-tests.ts unit",
    "test:integration": "bun run ../../scripts/package-tests.ts integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hootifactory/auth": "workspace:*",
    "@hootifactory/config": "workspace:*",
    "@hootifactory/core": "workspace:*",
    "@hootifactory/db": "workspace:*",
    "@hootifactory/observability": "workspace:*",
    "@hootifactory/queue": "workspace:*",
    "@hootifactory/registry": "workspace:*",
    "@hootifactory/scan-core": "workspace:*",
    "@hootifactory/storage": "workspace:*",
    "@hootifactory/types": "workspace:*"
  }
}
